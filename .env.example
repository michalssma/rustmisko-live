# RustMiskoLive — environment variables
# Zkopíruj jako .env a vyplň hodnoty
# .env je v .gitignore — NIKDY necommitovat!

# === POVINNE pro live bety (Polygon) ===
# Private key nove penezenky (MetaMask export) — nikdy necommitovat
PRIVATE_KEY=

# Bezpecnostni pojistka: pokud se executor rozbehne s jinou adresou, start spadne.
EXPECTED_WALLET_ADDRESS=

# === DOPORUCENE (jinak se vypnou telegram alerty) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Polling frequency
# Sníženo z 60s na 15s pro rychlejší reakci (aby neuniklo Arbitrage okno Valorantu a CS2)
ESPORTS_POLL_INTERVAL_SECS=15

# NTFY topic pro push notifikace
NTFY_TOPIC=rustmisko
